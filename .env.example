# ==========================================================================
# Plantilla de variables de entorno. Copia este archivo a `.env` y rellena
# los valores reales. NUNCA commitees el `.env` con secretos.
# Usado por docker-compose.yml para orquestar db + api + web.
# ==========================================================================

# --- PostgreSQL ---
POSTGRES_USER=gestor
POSTGRES_PASSWORD=cambia_esta_clave_segura
POSTGRES_DB=gestiontareas
POSTGRES_PORT=5432

# --- Backend / API ---
# DATABASE_URL apunta al servicio "db" dentro de la red de Docker Compose.
# Para desarrollo local fuera de Docker usa: postgresql://gestor:cambia_esta_clave_segura@localhost:5432/gestiontareas?schema=public
DATABASE_URL=postgresql://gestor:cambia_esta_clave_segura@db:5432/gestiontareas?schema=public
API_PORT=4000
NODE_ENV=production

# Secreto para firmar los JWT. Genera uno fuerte, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=reemplaza_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=1d

# Origen permitido para CORS (URL del frontend).
CORS_ORIGIN=http://localhost:8080

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Frontend (build time) ---
# El frontend habla con la API a través del proxy de nginx en /api,
# por lo que en producción suele bastar con una ruta relativa.
VITE_API_URL=/api

# Puerto público donde nginx sirve el frontend.
WEB_PORT=8080
